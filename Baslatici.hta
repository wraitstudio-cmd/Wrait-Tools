<!DOCTYPE html>
<html>
<head>
    <title>Wrait OS</title>
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <hta:application id="WraitOS" border="thin" caption="yes" showintaskbar="yes" singleinstance="yes" sysmenu="yes" windowstate="normal" scroll="no">

<style>
    body { background-color: #050505; color: #00ffcc; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 15px; overflow: hidden; }
    
    #upd-notice { 
        display: none; background: #ff3333; color: #fff; text-align: center; 
        padding: 8px; font-weight: bold; cursor: pointer; margin-bottom: 10px; border-radius: 4px; 
    }

    .container { 
        border: 1px solid #1a1a1a; background: #0a0a0a; height: 530px; 
        padding: 20px; display: flex; flex-direction: column; border-radius: 8px; 
    }

    h1 { text-align: center; font-size: 20px; letter-spacing: 5px; border-bottom: 1px solid #1a1a1a; padding-bottom: 15px; margin: 0 0 15px 0; }
    
    #readme-box { background: #000; border: 1px solid #111; padding: 12px; height: 100px; overflow-y: auto; margin-bottom: 20px; font-size: 12px; color: #888; border-radius: 4px; }

    .tools-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; overflow-y: auto; flex-grow: 1; }

    button { 
        background: #0d0d0d; color: #00ffcc; border: 1px solid #1a1a1a; padding: 12px; 
        cursor: pointer; font-weight: bold; border-radius: 4px; font-size: 11px;
    }
    button:hover { background: #00ffcc; color: #000; }

    .close-btn { background: #1a0505; color: #ff4444; border-color: #331111; margin-top: 15px; }
    .close-btn:hover { background: #ff4444; color: #fff; }
</style>

<script language="vbs">
    Set objShell = CreateObject("WScript.Shell")
    Set fso = CreateObject("Scripting.FileSystemObject")

    ' --- ANA ACILIS ---
    Sub Window_OnLoad
        window.resizeTo 850, 630
        
        ' 1. ReadMe'yi saniyeler icinde yukle
        On Error Resume Next
        If fso.FileExists("ReadMe.txt") Then
            document.getElementById("readme-box").innerText = fso.OpenTextFile("ReadMe.txt", 1).ReadAll
        Else
            document.getElementById("readme-box").innerText = "ReadMe.txt bulunamadi."
        End If

        ' 2. Aracları yukle
        LoadTools()

        ' 3. Guncelleme kontrolünü en son yap
        window.setTimeout "CheckUpdate", 3000
    End Sub

    Sub LoadTools()
        On Error Resume Next
        h = ""
        Set fld = fso.GetFolder("Tools")
        For Each f In fld.Files
            ext = LCase(fso.GetExtensionName(f.Name))
            If ext = "bat" Or ext = "exe" Or ext = "cmd" Then
                nm = fso.GetBaseName(f.Name)
                ' Hata veren tırnak yapısını düzelttik
                h = h & "<button onclick='RunTool(""" & Replace(f.Path, "\", "\\") & """)'>" & UCase(nm) & "</button>"
            End If
        Next
        document.getElementById("tools_list").innerHTML = h
    End Sub

    Sub RunTool(p)
        On Error Resume Next
        objShell.Run Chr(34) & p & Chr(34), 1, False
    End Sub

    Sub CheckUpdate()
        On Error Resume Next
        Set xml = CreateObject("MSXML2.XMLHTTP")
        xml.open "GET", "https://api.github.com/repos/wraitstudio-cmd/Wrait-Tools/commits/main", True
        xml.send
        
        t = Timer
        Do While xml.readyState <> 4
            If Timer > (t + 3) Then Exit Do 
        Loop

        If xml.Status = 200 Then
            sha = Mid(xml.responseText, InStr(xml.responseText, """sha"":""") + 7, 7)
            old = ""
            If fso.FileExists("core_hash.txt") Then old = Trim(fso.OpenTextFile("core_hash.txt", 1).ReadAll)
            
            If sha <> old And Len(sha) > 2 Then
                document.getElementById("upd-notice").style.display = "block"
                window.newSHA = sha
            End If
        End If
    End Sub

    Sub DoUpdate()
        If MsgBox("GUNCELLEME YUKLENSIN MI?", 36, "WRAIT OS") = 6 Then
            Set f = fso.CreateTextFile("core_hash.txt", True)
            f.Write window.newSHA
            f.Close
            
            p = objShell.ExpandEnvironmentStrings("%TEMP%") & "\Wrait_Os"
            Set b = fso.CreateTextFile("WraitUpdater.bat", True)
            b.WriteLine "@echo off"
            b.WriteLine "powershell -Command ""[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; Invoke-WebRequest -Uri 'https://github.com/wraitstudio-cmd/Wrait-Tools/archive/refs/heads/main.zip' -OutFile '" & p & "\sync.zip'"""
            b.WriteLine "powershell -Command ""Expand-Archive -Path '" & p & "\sync.zip' -DestinationPath '" & p & "\extracted' -Force"""
            b.WriteLine "xcopy /s /y """ & p & "\extracted\Wrait-Tools-main\*"" ""."" "
            b.WriteLine "start """" """ & Replace(window.location.pathname, "/", "") & """"
            b.WriteLine "exit"
            b.Close
            objShell.Run "WraitUpdater.bat", 0, False
            window.close
        End If
    End Sub

    Sub CloseApp()
        window.close
    End Sub
</script>
</head>

<body>
    <div id="upd-notice" onclick="DoUpdate()">YENI GUNCELLEME MEVCUT! TIKLA VE YUKLE</div>

    <div class="container">
        <h1>WRAIT OS // MASTER PANEL</h1>
        <div id="readme-box"></div>
        <div id="tools_list" class="tools-grid"></div>
        <button class="close-btn" onclick="CloseApp()">PANELİ KAPAT</button>
    </div>
</body>
</html>