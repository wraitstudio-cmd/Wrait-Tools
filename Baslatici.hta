<html>
<head>
<title>WRAIT OS - NEXT GEN CONTROL PANEL</title>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<hta:application 
    id="WraitOS"
    border="none"
    caption="yes"
    showintaskbar="yes"
    singleinstance="yes"
    sysmenu="yes"
    windowstate="normal"
    scroll="no"
    selection="no"
    innerborder="no"
>

<style>
    body {
        background-color: #020202;
        color: #00ffcc;
        font-family: 'Segoe UI', 'Consolas', sans-serif;
        margin: 0;
        padding: 0;
        overflow: hidden;
    }
    .main-wrapper {
        border: 2px solid #00ffcc;
        height: 100vh;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        background: radial-gradient(circle at center, #001a1a 0%, #020202 100%);
    }
    .header {
        padding: 20px;
        text-align: center;
        border-bottom: 1px solid #00ffcc;
        background: rgba(0, 255, 204, 0.05);
    }
    h1 { 
        margin: 0; 
        font-size: 32px; 
        letter-spacing: 5px; 
        text-shadow: 0 0 15px #00ffcc;
        font-weight: 900;
    }
    
    #lock-overlay {
        display: none;
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.98);
        z-index: 9999;
        text-align: center;
        padding-top: 100px;
    }
    
    .update-card {
        background: #000;
        border: 2px solid #ff0000;
        display: inline-block;
        padding: 40px;
        box-shadow: 0 0 30px #ff0000;
    }

    #readme-box {
        background: rgba(0, 10, 10, 0.8);
        border: 1px solid #004444;
        padding: 15px;
        height: 100px;
        margin: 15px;
        overflow-y: auto;
        font-size: 13px;
        color: #00cccc;
        line-height: 1.5;
    }

    .tools-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        overflow-y: auto;
        padding: 0 15px 15px 15px;
        flex-grow: 1;
    }

    .btn-tool {
        background: rgba(0, 40, 40, 0.3);
        color: #00ffcc;
        border: 1px solid #00ffcc;
        padding: 15px;
        cursor: pointer;
        font-weight: bold;
        text-transform: uppercase;
        transition: 0.2s;
        outline: none;
    }

    .btn-tool:hover { 
        background: #00ffcc; 
        color: #000; 
        box-shadow: 0 0 20px #00ffcc;
        transform: scale(1.02);
    }

    .status-bar {
        background: rgba(0, 255, 204, 0.1);
        padding: 10px 20px;
        font-size: 12px;
        display: flex;
        justify-content: space-between;
        border-top: 1px solid #004444;
    }

    .update-btn-active {
        background: linear-gradient(45deg, #ff0000, #990000);
        color: white;
        padding: 20px 40px;
        border: none;
        font-size: 20px;
        font-weight: bold;
        cursor: pointer;
        box-shadow: 0 0 15px #ff0000;
        text-decoration: none;
    }
    
    .update-btn-active:hover {
        background: #ff0000;
        box-shadow: 0 0 30px #ff0000;
    }

    .close-area {
        padding: 10px 15px;
    }
    .btn-exit {
        width: 100%;
        background: transparent;
        color: #ff4444;
        border: 1px solid #ff4444;
        padding: 8px;
        cursor: pointer;
    }
    .btn-exit:hover { background: #ff4444; color: #000; }
</style>

<script language="vbs">
    Set objShell = CreateObject("WScript.Shell")
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    Dim localVer, githubRaw, githubRepo
    localVer = "1.0" ' LOCAL SURUM
    githubRaw = "https://raw.githubusercontent.com/wraitstudio-cmd/Wrait-Tools/main/version.txt"
    githubRepo = "https://github.com/wraitstudio-cmd/Wrait-Tools"

    Sub Window_OnLoad
        window.resizeTo 900, 700
        ' Pencereyi ortala
        posX = (screen.width - 900) / 2
        posY = (screen.height - 700) / 2
        window.moveTo posX, posY
        
        document.getElementById("ui-local-ver").innerText = "SURUM: V" & localVer
        AutoCheck
    End Sub

    Sub AutoCheck
        On Error Resume Next
        Set xml = CreateObject("MSXML2.XMLHTTP")
        ' Cache onleyici timestamp
        xml.Open "GET", githubRaw & "?t=" & Timer, False
        xml.Send
        
        If xml.Status = 200 Then
            onlineVer = Trim(xml.responseText)
            document.getElementById("ui-online-ver").innerText = "GUNCEL: V" & onlineVer
            
            If onlineVer <> localVer Then
                document.getElementById("lock-overlay").style.display = "block"
                document.getElementById("ver-text").innerText = "YENI VERSIYON TESPIT EDILDI: V" & onlineVer
            Else
                LoadPanel
            End If
        Else
            document.getElementById("ui-online-ver").innerText = "OFFLINE MOD"
            LoadPanel
        End If
    End Sub

    Sub LoadPanel
        If fso.FileExists("ReadMe.txt") Then
            document.getElementById("readme-box").innerText = fso.OpenTextFile("ReadMe.txt", 1).ReadAll
        End If
        LoadTools
    End Sub

    Sub LoadTools
        strHTML = ""
        If fso.FolderExists("Tools") Then
            For Each file In fso.GetFolder("Tools").Files
                ext = LCase(fso.GetExtensionName(file.Name))
                If ext = "bat" Or ext = "exe" Or ext = "cmd" Then
                    fName = fso.GetBaseName(file.Name)
                    strHTML = strHTML & "<button class='btn-tool' onclick=""RunTool('" & Replace(file.Path, "\", "\\") & "')"">" & fName & "</button>"
                End If
            Next
        End If
        tools_list.innerHTML = strHTML
    End Sub

    Sub RunTool(p)
        objShell.Run Chr(34) & p & Chr(34), 1, False
    End Sub

    Sub StartUpdate
        ' Otomatik Updater Scripti
        Set batch = fso.CreateTextFile("WraitUpdater.bat", True)
        batch.WriteLine "@echo off"
        batch.WriteLine "title WRAIT OS AUTO UPDATER"
        batch.WriteLine "color 0c"
        batch.WriteLine "echo [!] DOSYALAR INDIRILIYOR..."
        batch.WriteLine "powershell -Command ""Invoke-WebRequest -Uri 'https://github.com/wraitstudio-cmd/Wrait-Tools/archive/refs/heads/main.zip' -OutFile 'update.zip'"""
        batch.WriteLine "echo [!] AYIKLANIYOR..."
        batch.WriteLine "powershell -Command ""Expand-Archive -Path 'update.zip' -DestinationPath 'temp_upd' -Force"""
        batch.WriteLine "echo [!] DOSYALAR DEGISTIRILIYOR..."
        batch.WriteLine "xcopy /s /y ""temp_upd\Wrait-Tools-main\*"" ""."" "
        batch.WriteLine "rd /s /q temp_upd"
        batch.WriteLine "del /f /q update.zip"
        batch.WriteLine "echo [OK] GUNCELLEME TAMAMLANDI!"
        batch.WriteLine "start Baslatici.hta"
        batch.WriteLine "del ""%~f0"""
        batch.Close
        
        objShell.Run "WraitUpdater.bat", 1, False
        window.close
    End Sub
</script>
</head>

<body>
    <!-- KILIT EKRANI -->
    <div id="lock-overlay">
        <div class="update-card">
            <h1 style="color:#ff0000; text-shadow: 0 0 20px #ff0000; margin-bottom:10px;">SISTEM KILITLI</h1>
            <p id="ver-text" style="font-size:18px; color:white;"></p>
            <p style="color:#888; margin-bottom:30px;">Kullanmaya devam etmek icin guncelleme zorunludur.</p>
            <button class="update-btn-active" onclick="StartUpdate">OTOMATIK GUNCELLEMEYI BASLAT</button>
        </div>
    </div>

    <!-- ANA PANEL -->
    <div class="main-wrapper">
        <div class="header">
            <h1>WRAIT OS MASTER PANEL</h1>
        </div>
        
        <div id="readme-box">Sistem yukleniyor...</div>
        
        <div id="tools_list" class="tools-grid"></div>

        <div class="close-area">
            <button class="btn-exit" onclick="window.close">PANELI KAPAT</button>
        </div>

        <div class="status-bar">
            <span id="ui-online-ver">BAGLANTI KONTROL EDILIYOR...</span>
            <span style="color:#fff; font-weight:bold;">DEVELOPER: WRAITGAME</span>
            <span id="ui-local-ver" style="color:#00ffcc;">SURUM: V--</span>
        </div>
    </div>
</body>
</html>